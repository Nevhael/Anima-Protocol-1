{
  "framework": "vite",
  "installCommand": "pnpm install --frozen-lockfile",
  "buildCommand": "PORT=23660 BASE_PATH=/ pnpm --filter @workspace/anima-protocol run build",
  "outputDirectory": "artifacts/anima-protocol/dist/public",
  "rewrites": [
    {
      "source": "/api/:path*",
      "destination": "https://anima-protocol.replit.app/api/:path*"
    },
    {
      "source": "/((?!api/).*)",
      "destination": "/index.html"
    }
  ]
}
