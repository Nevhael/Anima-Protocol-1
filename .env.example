# Copy to repo root: cp .env.example .env
# Both api-server and anima-protocol load /workspace/.env automatically.

DATABASE_URL=postgresql://anima:anima_dev@localhost:5432/anima_dev
OPENAI_API_KEY=sk-...
CLERK_PUBLISHABLE_KEY=pk_test_...
CLERK_SECRET_KEY=sk_test_...
# Must be pk_* (publishable), never sk_* (secret). Match CLERK_PUBLISHABLE_KEY.
VITE_CLERK_PUBLISHABLE_KEY=pk_test_...
# Leave empty for auto-proxy on production hosts; set "none" to disable on Vercel
VITE_CLERK_PROXY_URL=
VITE_MIXPANEL_TOKEN=
VITE_ADMIN_EMAILS=davins56@gmail.com
ELEVENLABS_API_KEY=

# Ports (FRONTEND_PORT for Vite, API_PORT for Express)
FRONTEND_PORT=23660
API_PORT=8080
BASE_PATH=/
API_PROXY_TARGET=http://localhost:8080
NODE_ENV=development
